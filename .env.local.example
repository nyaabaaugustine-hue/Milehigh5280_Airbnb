NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# 📧 EMAIL — Gmail SMTP (Nodemailer)
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO SET UP (takes 2 minutes):
#
# 1. Go to: https://myaccount.google.com/security
# 2. Enable "2-Step Verification" (required for App Passwords)
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Choose app: "Mail" → device: "Other" → name it "Milehigh5280"
# 5. Copy the 16-character password shown (no spaces)
# 6. Paste it below as GMAIL_PASS
#
# Use your SENDING gmail account (e.g. rehobothproperties@gmail.com)
# Emails will be DELIVERED TO → ADMIN_EMAIL (nyaaba.augustine@gmail.com)
#
GMAIL_USER=rehobothproperties@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Admin inbox — all contact & booking emails go here
ADMIN_EMAIL=nyaaba.augustine@gmail.com

