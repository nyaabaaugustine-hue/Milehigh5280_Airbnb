NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paystack (Ghana payments)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key_here
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_here

# Stripe (international payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here

# WhatsApp Business number (with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=233000000000

# Contact form (e.g. Formspree or EmailJS)
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# Google Maps API (for map embeds)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
