# ─── Email (Gmail SMTP) ───────────────────────────────────────────
# Your Gmail address (the one that sends booking/contact emails)
GMAIL_USER=your-gmail@gmail.com

# Gmail App Password — NOT your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be ON)
GMAIL_PASS=your-16-character-app-password

# Admin inbox — where booking & contact notifications arrive
ADMIN_EMAIL=herbertprempeh@gmail.com

# ─── Site URL (set this in Vercel dashboard too) ──────────────────
NEXT_PUBLIC_SITE_URL=https://thepalmayimensah.com

# ─── WhatsApp / Phone ─────────────────────────────────────────────
# Ghana number: +233 059 975 4270 (digits only for wa.me links)
NEXT_PUBLIC_WHATSAPP_NUMBER=233599754270

# ─── Analytics (Optional) ─────────────────────────────────────────
# Hotjar - Get your ID from https://www.hotjar.com
# NEXT_PUBLIC_HOTJAR_ID=XXXXXXXX

# Microsoft Clarity - Get your ID from https://clarity.microsoft.com
# NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX

# ─── Airtable CMS (Headless CMS) ───────────────────────────────
# Get your Personal Access Token from https://airtable.com/create/tokens
# Create a new base with: Properties, Amenities, Rooms, Reviews, Blog Posts tables
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Get your Base ID from https://airtable.com/developers/web/api/introduction
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ─── Neon Database (PostgreSQL) ───────────────────────────────
# Get connection string from https://neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.neon.tech/dbname?sslmode=require

# ─── On-Demand Revalidation (ISR) ─────────────────────────────
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=your-secure-random-secret-here

# ─── Authentication ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# ─── AI Providers ───────────────────────────────────────────────
# Groq API (optional) - Get from https://console.groq.com/keys
GROK_API_KEY=your-groq-api-key

# Cloudflare Workers AI (optional fallback)
# Get API Token from: Cloudflare Dashboard → Profile → API Tokens → Create Custom Token
# Account ID from: Cloudflare Dashboard → Overview
CF_API_TOKEN=your-cf-api-token
CF_ACCOUNT_ID=your-cf-account-id
